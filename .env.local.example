# Copy this file to .env.local for local dev (`vercel dev`).
# In production, set these via `vercel env add` or the Vercel dashboard.
# NEVER commit .env.local — it's in .gitignore.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# The shared password testers must enter to use the dashboard.
# Pick anything — a long random phrase is best.
SHARED_PASSWORD=change-me-to-something-long
